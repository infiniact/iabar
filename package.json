{
  "name": "iabar",
  "version": "0.1.0",
  "description": "A Chrome MV3 extension powered by the iacoder agent harness compiled to WebAssembly",
  "type": "module",
  "private": true,
  "scripts": {
    "build:wasm": "wasm-pack build crates/iabar-wasm --target web --out-dir ../../src/wasm --out-name iabar_wasm",
    "build:wasm:dev": "wasm-pack build crates/iabar-wasm --dev --target web --out-dir ../../src/wasm --out-name iabar_wasm",
    "dev": "pnpm run build:wasm:dev && vite",
    "build": "pnpm run build:wasm && pnpm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.299",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-top-level-await": "^1.5.0",
    "vite-plugin-wasm": "^3.4.0"
  }
}
